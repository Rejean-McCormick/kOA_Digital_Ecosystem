%% docs/08-reference/diagrams/system-context.mmd
graph TD

  %% Actors
  Sources[External Sources\n(datasets, feeds, uploads)]
  Users[Users / Orgs]
  Tools[External Tools\n(APIs, services)]

  %% Core planes
  subgraph ControlPlane[Control Plane]
    Orgo[Orgo\nWorkflow • Governance • Gating • Audit]
  end

  subgraph ResolutionPlane[Resolution Plane]
    Sentient[SenTient\nResolution • Normalization • Ambiguity]
  end

  subgraph TruthPlane[Truth Plane (Canon)]
    Kristal[Kristal\nExchange (Canonical) • Runtime Pack (Offline)]
    Validator[Validation Engine\nDeterministic Acceptance Gate]
  end

  subgraph ArticulationPlane[Articulation Plane]
    ArchS[Architect-Strategy\nPlan → Cases/Tasks • Render Specs]
    ArchR[Architect-Render\nDeterministic Output • Trace Map\nNo New Facts]
  end

  subgraph ExecutionPlane[Execution Plane]
    Swarm[SwarmCraft\nExecution • Telemetry]
  end

  subgraph InterfacePlane[Distribution + Interface Plane]
    KDist[Konnaxion (Distribution)\nVerify • Cache • Activate • Rollback]
    KUI[Konnaxion (Interface)\nNavigate • Request Render • Capture Feedback]
  end

  subgraph TrustPlane[Trust + Impact Plane]
    Ekoh[EkoH\nTrust • Ethics • Votes • Impact Ledger]
  end

  %% Data / Artifact flow
  Sources -->|Snapshots + Provenance| Orgo
  Orgo -->|Work Orders| Swarm
  Swarm -->|Tool Calls / Outputs| Tools
  Swarm -->|Telemetry / Results| Orgo

  Orgo -->|Claim-IR (proposals)| Sentient
  Sentient -->|Resolved Claim-IR| Validator
  Validator -->|Validation Report (PASS/FAIL)| Orgo
  Validator -->|PASS → Compile Inputs| Kristal

  Kristal -->|Exchange + Runtime Pack| Orgo
  Orgo -->|Publish / Release| KDist
  KDist -->|Verified Active Pack Set| KUI

  KUI -->|Render Request\n(pack_id + spec)| ArchS
  ArchS -->|Plan → Cases/Tasks| Orgo
  ArchS -->|Render Spec| ArchR
  KUI -->|Verified Pack Query Results| ArchR
  ArchR -->|Render Bundle\n(output + trace_map)| KUI
  KUI -->|Human-facing Output| Users

  %% Feedback loop (governed)
  Users -->|Feedback / Corrections / Votes| KUI
  KUI -->|Signals → New governed work| Orgo
  KUI -->|Signals| Ekoh
  Ekoh -->|Trust metrics / weighting| Orgo
  Ekoh -->|Trust surfaces| KUI
