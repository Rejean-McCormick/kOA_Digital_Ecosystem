{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://koa.example/schemas/release-record.schema.json",
  "title": "kOA Release Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "release_id",
    "created_at",
    "created_by",
    "build_ref",
    "artifacts",
    "channels",
    "strategy",
    "status",
    "updated_at",
    "events"
  ],
  "properties": {
    "release_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "created_by": {
      "type": "string",
      "minLength": 1,
      "description": "Principal identity (user/service) that created the release record."
    },
    "build_ref": {
      "type": "string",
      "minLength": 1,
      "description": "Reference to the Build Record (content ref or ID)."
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/artifact_ref" }
    },
    "channels": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/channel_target" }
    },
    "strategy": {
      "$ref": "#/$defs/rollout_strategy"
    },
    "verification_policy_ref": {
      "type": "string",
      "minLength": 1
    },
    "activation_policy_ref": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "DRAFT",
        "QUEUED",
        "VERIFYING",
        "VERIFIED",
        "RELEASING",
        "RELEASED",
        "PAUSED",
        "ROLLED_BACK",
        "FAILED",
        "CANCELED"
      ]
    },
    "status_reason": {
      "type": "string"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "events": {
      "type": "array",
      "items": { "$ref": "#/$defs/release_event" }
    }
  },
  "$defs": {
    "hash": {
      "type": "object",
      "additionalProperties": false,
      "required": ["alg", "value"],
      "properties": {
        "alg": {
          "type": "string",
          "minLength": 1,
          "description": "Hash algorithm identifier (e.g., sha256)."
        },
        "value": {
          "type": "string",
          "minLength": 1,
          "description": "Digest value (encoding is implementation-defined; typically hex or base64url)."
        }
      }
    },
    "artifact_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_type", "artifact_ref"],
      "properties": {
        "artifact_type": {
          "type": "string",
          "minLength": 1,
          "description": "Artifact type label (e.g., runtime_pack, exchange, render_bundle)."
        },
        "artifact_ref": {
          "type": "string",
          "minLength": 1,
          "description": "Content reference or ID of the artifact."
        },
        "artifact_hash": {
          "$ref": "#/$defs/hash"
        },
        "compat": {
          "type": "object",
          "additionalProperties": true,
          "description": "Optional compatibility metadata; shape is implementation-defined."
        }
      }
    },
    "channel_target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["channel_id"],
      "properties": {
        "channel_id": {
          "type": "string",
          "minLength": 1
        },
        "target_cohorts": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "constraints": {
          "type": "object",
          "additionalProperties": true,
          "description": "Policy constraints or rollout guards; shape is implementation-defined."
        }
      }
    },
    "rollout_strategy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["all_at_once", "percentage", "staged", "pinned"]
        },
        "percentage": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Required when mode=percentage."
        },
        "stages": {
          "type": "array",
          "items": { "$ref": "#/$defs/rollout_stage" },
          "description": "Used when mode=staged."
        }
      },
      "allOf": [
        {
          "if": { "properties": { "mode": { "const": "percentage" } } },
          "then": { "required": ["percentage"] }
        },
        {
          "if": { "properties": { "mode": { "const": "staged" } } },
          "then": { "required": ["stages"] }
        }
      ]
    },
    "rollout_stage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "target_cohorts": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "conditions": {
          "type": "object",
          "additionalProperties": true,
          "description": "Gate conditions (health checks, time windows, manual approval, etc.)."
        }
      }
    },
    "release_event": {
      "type": "object",
      "additionalProperties": false,
      "required": ["at", "type", "actor"],
      "properties": {
        "at": { "type": "string", "format": "date-time" },
        "type": {
          "type": "string",
          "minLength": 1,
          "description": "Event type (e.g., QUEUED, VERIFY_STARTED, VERIFY_FAILED, ACTIVATE_SUCCEEDED, ROLLBACK_SUCCEEDED)."
        },
        "actor": { "type": "string", "minLength": 1 },
        "details": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}