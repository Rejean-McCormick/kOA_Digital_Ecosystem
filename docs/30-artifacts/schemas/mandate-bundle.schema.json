{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:koa:schema:mandate-bundle:1.0.0",
  "title": "Mandate Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "kind",
    "bundle_id",
    "created_at",
    "issuer",
    "mandate",
    "policies"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "SemVer for this schema.",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "kind": {
      "type": "string",
      "const": "mandate_bundle"
    },
    "bundle_id": {
      "type": "string",
      "description": "Bundle identifier (content-addressed or UUID)."
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "issuer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["organization_id", "issuer_id"],
      "properties": {
        "organization_id": {
          "type": "string",
          "description": "Owning org identifier (UUID or stable org key)."
        },
        "issuer_id": {
          "type": "string",
          "description": "Issuer identity within org (service/user id)."
        },
        "contact": {
          "type": "string",
          "description": "Optional human contact or team alias."
        }
      }
    },
    "mandate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mandate_id", "name"],
      "properties": {
        "mandate_id": {
          "type": "string",
          "description": "Mandate identifier."
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "objectives": {
          "type": "array",
          "items": { "type": "string" }
        },
        "constraints": {
          "type": "array",
          "items": { "type": "string" }
        },
        "scope": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "domains": {
              "type": "array",
              "items": { "type": "string" }
            },
            "locales": {
              "type": "array",
              "items": { "type": "string" }
            },
            "audiences": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    },
    "policies": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/policy" }
    },
    "content_hash": {
      "description": "Optional digest of the canonicalized bundle payload.",
      "$ref": "#/$defs/hash"
    },
    "signatures": {
      "type": "array",
      "items": { "$ref": "#/$defs/signature" }
    },
    "labels": {
      "type": "array",
      "items": { "type": "string" }
    },
    "links": {
      "type": "array",
      "items": { "$ref": "#/$defs/link" }
    }
  },
  "$defs": {
    "hash": {
      "type": "object",
      "additionalProperties": false,
      "required": ["alg", "value"],
      "properties": {
        "alg": {
          "type": "string",
          "description": "Hash algorithm identifier (e.g., sha256)."
        },
        "value": {
          "type": "string",
          "description": "Digest value; encoding is determined by the profile (commonly hex or base64)."
        }
      }
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key_id", "alg", "signature"],
      "properties": {
        "key_id": {
          "type": "string",
          "description": "Key identifier for verification."
        },
        "alg": {
          "type": "string",
          "description": "Signature algorithm identifier."
        },
        "signature": {
          "type": "string",
          "description": "Signature bytes (base64url recommended)."
        },
        "signed_fields": {
          "type": "array",
          "description": "Optional JSON Pointer list describing which fields were signed.",
          "items": { "type": "string" }
        }
      }
    },
    "link": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rel", "href"],
      "properties": {
        "rel": { "type": "string" },
        "href": { "type": "string" },
        "type": { "type": "string" }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy_id", "version", "name", "enforcement", "rules"],
      "properties": {
        "policy_id": {
          "type": "string",
          "description": "Stable policy identifier."
        },
        "version": {
          "type": "string",
          "description": "Policy version label (SemVer recommended)."
        },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "enforcement": {
          "type": "string",
          "description": "How strictly the policy must be enforced.",
          "enum": ["MUST", "SHOULD", "MAY"]
        },
        "effective_from": {
          "type": "string",
          "format": "date-time"
        },
        "effective_to": {
          "type": "string",
          "format": "date-time"
        },
        "policy_hash": {
          "description": "Optional digest of the canonical policy document/rules.",
          "$ref": "#/$defs/hash"
        },
        "rules": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/rule" }
        },
        "parameters": {
          "type": "object",
          "description": "Optional policy parameters (must be treated as part of policy identity if used).",
          "additionalProperties": true
        },
        "applies_to": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "stages": {
              "type": "array",
              "items": { "type": "string" }
            },
            "artifacts": {
              "type": "array",
              "items": { "type": "string" }
            },
            "components": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    },
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rule_id", "type"],
      "properties": {
        "rule_id": { "type": "string" },
        "type": {
          "type": "string",
          "description": "Rule family identifier (e.g., validation_gate, render_trace, safety, privacy)."
        },
        "severity": {
          "type": "string",
          "enum": ["INFO", "WARN", "ERROR", "FATAL"],
          "default": "ERROR"
        },
        "description": { "type": "string" },
        "config": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}