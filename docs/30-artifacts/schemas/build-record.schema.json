{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:koa:schema:build-record:1",
  "title": "Build Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "build_id",
    "record_version",
    "created_at",
    "mandate_bundle_ref",
    "inputs",
    "pipeline",
    "stages",
    "outputs"
  ],
  "properties": {
    "build_id": {
      "type": "string",
      "minLength": 1,
      "description": "kOA build identifier (control-plane identifier; not content-addressed)."
    },
    "record_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "Version of this Build Record envelope."
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "trigger": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["manual", "schedule", "webhook", "incident", "release", "other"]
        },
        "actor": { "type": "string" },
        "reason": { "type": "string" },
        "source_ref": { "$ref": "#/$defs/content_ref" }
      }
    },
    "mandate_bundle_ref": {
      "$ref": "#/$defs/content_ref",
      "description": "Content-addressed reference to the kOA Mandate Bundle used for this build."
    },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["snapshots"],
      "properties": {
        "snapshots": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/content_ref" },
          "description": "Content-addressed references to immutable input snapshots."
        },
        "snapshot_manifest_ref": {
          "$ref": "#/$defs/content_ref",
          "description": "Optional content-addressed reference to a snapshot manifest (provenance/metadata)."
        },
        "notes": { "type": "string" }
      }
    },
    "pipeline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pipeline_id", "toolchain"],
      "properties": {
        "pipeline_id": {
          "type": "string",
          "minLength": 1,
          "description": "Identifier for the pipeline definition used (e.g., a workflow name/version)."
        },
        "toolchain": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "orgo_version": { "type": "string" },
            "compiler_version": { "type": "string" },
            "validator_version": { "type": "string" },
            "resolver_version": { "type": "string" },
            "render_version": { "type": "string" }
          },
          "description": "Pinned toolchain versions used by the build."
        },
        "source": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "repo": { "type": "string" },
            "commit": { "type": "string" },
            "branch": { "type": "string" },
            "build_system": { "type": "string" }
          }
        },
        "environment": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "env": { "type": "string" },
            "region": { "type": "string" },
            "runner_id": { "type": "string" }
          }
        }
      }
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/stage_record" },
      "description": "Ordered stage execution records for the build."
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["validation", "kristal"],
      "properties": {
        "validation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["report_ref", "status"],
          "properties": {
            "report_ref": { "$ref": "#/$defs/content_ref" },
            "status": { "type": "string", "enum": ["PASS", "FAIL"] }
          },
          "description": "Opaque reference to the validation report artifact produced by the validator."
        },
        "kristal": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "exchange_ref": {
              "$ref": "#/$defs/content_ref",
              "description": "Opaque reference to the Kristal Exchange (or its manifest) produced by the Kristal compiler."
            },
            "runtime_pack_ref": {
              "$ref": "#/$defs/content_ref",
              "description": "Opaque reference to the Runtime Pack (or its manifest) produced by the Kristal compiler."
            }
          },
          "description": "Kristal-produced artifacts referenced opaquely (no field-level duplication)."
        },
        "render_bundles": {
          "type": "array",
          "items": { "$ref": "#/$defs/content_ref" },
          "description": "Optional content refs for deterministic Render Bundles produced downstream."
        }
      }
    },
    "checksums": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "build_record_hash": { "$ref": "#/$defs/hash_ref" }
      },
      "description": "Optional integrity data for this record as stored/transported."
    }
  },
  "$defs": {
    "content_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["alg", "value"],
      "properties": {
        "alg": {
          "type": "string",
          "minLength": 1,
          "description": "Hash/identifier algorithm name (e.g., sha256)."
        },
        "value": {
          "type": "string",
          "minLength": 1,
          "description": "Algorithm-specific value (e.g., hex digest, CID)."
        },
        "uri": {
          "type": "string",
          "format": "uri",
          "description": "Optional retrieval location; not identity."
        }
      }
    },
    "hash_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["alg", "value"],
      "properties": {
        "alg": { "type": "string", "minLength": 1 },
        "value": { "type": "string", "minLength": 1 }
      }
    },
    "stage_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "status"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Stage identifier (e.g., ingest, extract, resolve, validate, compile, distribute)."
        },
        "status": {
          "type": "string",
          "enum": ["PASS", "FAIL", "ERROR", "SKIP"]
        },
        "started_at": { "type": "string", "format": "date-time" },
        "ended_at": { "type": "string", "format": "date-time" },
        "inputs": {
          "type": "array",
          "items": { "$ref": "#/$defs/content_ref" }
        },
        "outputs": {
          "type": "array",
          "items": { "$ref": "#/$defs/content_ref" }
        },
        "metrics": {
          "type": "object",
          "additionalProperties": true
        },
        "notes": { "type": "string" }
      }
    }
  }
}