{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/validation-report.schema.json",
  "title": "Validation Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "report_id",
    "created_at",
    "status",
    "stage",
    "subject"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Schema version for this Validation Report format (e.g., '1.0.0').",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "report_id": {
      "type": "string",
      "description": "Content-addressed or otherwise stable ID for this report (e.g., 'sha256:...').",
      "minLength": 8
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "UTC ISO-8601 timestamp when the report was produced."
    },
    "status": {
      "type": "string",
      "enum": ["PASS", "FAIL"],
      "description": "Deterministic acceptance outcome. FAIL must block downstream compile."
    },
    "stage": {
      "type": "string",
      "enum": ["VALIDATE"],
      "description": "Pipeline stage producing this report."
    },
    "tenant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["organization_id"],
      "properties": {
        "organization_id": {
          "type": ["string", "null"],
          "description": "Multi-tenant boundary key. Null may denote global/default scope."
        },
        "environment": {
          "type": "string",
          "description": "Optional environment name (e.g., 'prod', 'staging')."
        }
      }
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["build_id", "inputs"],
      "properties": {
        "build_id": {
          "type": "string",
          "description": "Orgo/Kristal build identifier this validation applies to."
        },
        "workflow_id": {
          "type": "string",
          "description": "Optional Orgo workflow identifier."
        },
        "case_id": {
          "type": "string",
          "description": "Optional Orgo case identifier associated with this build."
        },
        "inputs": {
          "type": "object",
          "additionalProperties": false,
          "required": ["resolved_claim_ir_ref"],
          "properties": {
            "claim_ir_ref": {
              "type": "string",
              "description": "Optional reference to the Claim-IR batch used."
            },
            "resolved_claim_ir_ref": {
              "type": "string",
              "description": "Reference to the Resolved Claim-IR batch being validated."
            },
            "input_snapshots": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Optional content-addressed references to raw input snapshots."
            }
          }
        },
        "policy_selections": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Portable policy identifiers used for validation."
        },
        "config_hash": {
          "type": "string",
          "description": "Hash of the full build/validation configuration."
        },
        "canonicalization_profile": {
          "type": "string",
          "description": "Canonicalization profile identifier (e.g., 'jcs-rfc8785')."
        },
        "canonicalization_version": {
          "type": "string",
          "description": "Canonicalization profile version."
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "checks_run": { "type": "integer", "minimum": 0 },
        "checks_failed": { "type": "integer", "minimum": 0 },
        "warnings": { "type": "integer", "minimum": 0 },
        "notes": {
          "type": "string",
          "description": "Human-readable notes (must not change PASS/FAIL semantics)."
        }
      }
    },
    "failures": {
      "type": "array",
      "description": "Failures causing status=FAIL. Must be present and non-empty when FAIL.",
      "items": { "$ref": "#/$defs/issue" }
    },
    "warnings": {
      "type": "array",
      "description": "Non-fatal issues (status may still be PASS).",
      "items": { "$ref": "#/$defs/issue" }
    },
    "determinism": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "deterministic": {
          "type": "boolean",
          "const": true,
          "description": "This report is defined to be deterministic for a given subject+policy+config."
        },
        "profile": {
          "type": "string",
          "description": "Optional determinism profile identifier (e.g., 'strict')."
        }
      }
    },
    "integrity": {
      "type": "object",
      "description": "Optional integrity material for the report itself. If present, verifiers must fail-closed.",
      "additionalProperties": false,
      "properties": {
        "hash": {
          "type": "string",
          "description": "Content hash of the canonicalized report excluding signature envelope (e.g., 'sha256:...')."
        },
        "signature_envelope": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "alg": { "type": "string" },
            "kid": { "type": "string" },
            "sig": { "type": "string", "description": "Signature bytes (encoding specified by implementation)." }
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "status": { "const": "FAIL" } },
        "required": ["status"]
      },
      "then": {
        "required": ["failures"],
        "properties": {
          "failures": { "minItems": 1 }
        }
      }
    },
    {
      "if": {
        "properties": { "status": { "const": "PASS" } },
        "required": ["status"]
      },
      "then": {
        "properties": {
          "failures": { "maxItems": 0 }
        }
      }
    }
  ],
  "$defs": {
    "issue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": {
          "type": "string",
          "description": "Stable deterministic error code (e.g., 'VAL_SCHEMA_FAIL', 'VAL_CONFLICT', 'VAL_PROVENANCE_MISSING').",
          "minLength": 3
        },
        "message": {
          "type": "string",
          "description": "Human-readable explanation (must not affect determinism).",
          "minLength": 1
        },
        "severity": {
          "type": "string",
          "enum": ["ERROR", "WARNING"],
          "default": "ERROR"
        },
        "where": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "artifact_ref": {
              "type": "string",
              "description": "Reference to the artifact containing the issue (e.g., resolved_claim_ir_ref)."
            },
            "json_pointer": {
              "type": "string",
              "description": "JSON Pointer to the failing field, if applicable."
            },
            "claim_id": {
              "type": "string",
              "description": "Optional claim identifier related to the issue."
            }
          }
        },
        "evidence": {
          "type": "array",
          "description": "Optional evidence pointers supporting the issue.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "ref": { "type": "string", "description": "Content-addressed reference." },
              "note": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
